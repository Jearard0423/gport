<div>
  <div class="container1">
    <div class="header">
    <h1 class="text-4xl font-bold mb-4">Welcome to GPort</h1>
    <p class="text-lg text-gray-700 mb-6">Your gateway to seamless project management and collaboration.</p>
    </div>
     <div class="inputs" style="display:flex; flex-direction:column; gap:2rem;">
      <%= form_with url: user_session_path, local: true do |f| %>
      <label for=username class="block text-sm font-medium text-gray-700">Username</label>
      <%= f.text_field :username, style: "border: 1px solid #0b0a0a; padding: 0.5rem; border-radius: 0.25rem;" %>
      <label for=password class="block text-sm font-medium text-gray-700">Password</label>
      <%= f.password_field :password, style: "border: 1px solid #0b0a0a; padding: 0.5rem; border-radius: 0.25rem;" %>
      <%= f.submit "Login", style: "background-color: #4A90E2; color: white; padding: 0.5rem 1rem; border: none; border-radius: 0.25rem; cursor: pointer;" %>
      <a href="/users/sign_up">Don't have an account? Sign up</a>
      <% end %>
     </div>
  </div> 


</div>
